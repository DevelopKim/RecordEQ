{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RecordEQ",
  "version": "0.1.0",
  "identifier": "com.local.recordeq",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "RecordEQ",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 500,
        "decorations": true,
        "resizable": true,
        "center": true,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "macOS": {
      "entitlements": "./Entitlements.plist",
      "infoPlist": "./Info.plist"
    }
  }
}
